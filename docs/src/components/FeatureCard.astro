---
interface Props {
	title: string;
	description: string;
	icon: string;
}

const { title, description, icon } = Astro.props;
---

<div
	class="group relative overflow-hidden rounded-xl border border-amber-200/60 bg-white p-6 transition-all duration-300 hover:border-amber-300/80 hover:bg-amber-50/50 dark:border-amber-900/20 dark:bg-[#1a1714] dark:hover:border-amber-700/40 dark:hover:bg-[#1f1b17]"
>
	<!-- Subtle glow on hover -->
	<div
		class="pointer-events-none absolute -right-8 -top-8 h-32 w-32 rounded-full bg-amber-500/0 blur-3xl transition-all duration-500 group-hover:bg-amber-500/5"
	>
	</div>

	<div class="relative">
		<div class="mb-4 h-6 w-6 text-amber-600 dark:text-amber-500"><Fragment set:html={icon} /></div>
		<h3 class="mb-2 font-['Playfair_Display'] text-lg font-semibold text-amber-900 dark:text-amber-100">{title}</h3>
		<p class="font-['Source_Serif_4'] text-sm leading-relaxed text-[#8d7e68] dark:text-[#a89a84]">{description}</p>
	</div>
</div>
