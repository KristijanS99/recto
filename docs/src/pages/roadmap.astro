---
// biome-ignore lint/correctness/noUnusedImports: used in Astro template
import Footer from '../components/Footer.astro';
// biome-ignore lint/correctness/noUnusedImports: used in Astro template
import ScrollReveal from '../components/ScrollReveal.astro';
import rawRoadmapData from '../data/roadmap.json';
// biome-ignore lint/correctness/noUnusedImports: used in Astro template
import Landing from '../layouts/Landing.astro';

// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

// Sort: in-progress first, planned second, done last
const statusOrder: Record<string, number> = {
  'in-progress': 0,
  planned: 1,
  done: 2,
};

// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const roadmapData = [...rawRoadmapData].sort(
  (a, b) => (statusOrder[a.status] ?? 1) - (statusOrder[b.status] ?? 1),
);

// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const statusColors: Record<
  string,
  { bg: string; text: string; darkBg: string; darkText: string; label: string }
> = {
  planned: {
    bg: 'bg-amber-100',
    text: 'text-amber-700',
    darkBg: 'dark:bg-amber-900/20',
    darkText: 'dark:text-amber-400',
    label: 'Planned',
  },
  'in-progress': {
    bg: 'bg-blue-100',
    text: 'text-blue-700',
    darkBg: 'dark:bg-blue-900/20',
    darkText: 'dark:text-blue-400',
    label: 'In Progress',
  },
  done: {
    bg: 'bg-emerald-100',
    text: 'text-emerald-700',
    darkBg: 'dark:bg-emerald-900/20',
    darkText: 'dark:text-emerald-400',
    label: 'Done',
  },
};

// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const typeLabels: Record<string, string> = {
  feature: 'Feature',
  bug: 'Bug',
  improvement: 'Improvement',
};

// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const categoryLabels: Record<string, string> = {
  api: 'API',
  mcp: 'MCP',
  web: 'Web',
  infra: 'Infra',
  root: 'Monorepo',
};
---

<Landing title="Roadmap — Recto" description="What's next for Recto. Track upcoming features, current work, and completed milestones.">
	<section class="pt-32 pb-14 lg:pt-40 lg:pb-20">
		<div class="mx-auto max-w-3xl px-6">
			<ScrollReveal>
				<div class="mb-4">
					<a
						href={base}
						class="inline-flex items-center gap-1.5 font-['Source_Serif_4'] text-sm text-amber-600 transition-colors hover:text-amber-500 dark:text-amber-500 dark:hover:text-amber-400"
					>
						<svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M11 17l-5-5m0 0l5-5m-5 5h12" />
						</svg>
						Back to home
					</a>
				</div>
				<div class="mb-10">
					<h1 class="font-['Playfair_Display'] text-4xl font-bold text-amber-950 sm:text-5xl dark:text-amber-50">
						Roadmap
					</h1>
					<p class="mt-4 font-['Source_Serif_4'] text-lg text-[#8d7e68] dark:text-[#a89a84]">
						What's next for Recto. Track upcoming features, current work, and completed milestones.
					</p>
				</div>
			</ScrollReveal>

			<!-- Timeline -->
			<div class="relative ml-4">
				<!-- Vertical line -->
				<div class="absolute left-0 top-0 bottom-0 w-px bg-gradient-to-b from-amber-300/60 via-amber-300/30 to-transparent dark:from-amber-700/40 dark:via-amber-700/20"></div>

				<div class="space-y-6">
					{roadmapData.map((item, i) => {
						const status = statusColors[item.status] || statusColors.planned;
						const typeLabel = typeLabels[item.type] || item.type;
						const categoryLabel = categoryLabels[item.category] || item.category;
						return (
							<ScrollReveal delay={i * 100}>
								<div class="relative pl-8">
									{/* Timeline dot */}
									<div class="absolute left-0 top-5 h-2.5 w-2.5 -translate-x-1/2 rounded-full border-2 border-amber-400 bg-white dark:border-amber-600 dark:bg-[#0f0d0b]"></div>

									{/* Card */}
									<div class="rounded-xl border border-amber-200/60 bg-white p-5 transition-colors duration-300 dark:border-amber-900/20 dark:bg-[#1a1714]">
										{/* Badges row */}
										<div class="mb-3 flex flex-wrap items-center gap-2">
											<span class={`inline-block rounded-full px-2.5 py-0.5 font-['JetBrains_Mono'] text-[11px] font-medium ${status.bg} ${status.text} ${status.darkBg} ${status.darkText}`}>
												{status.label}
											</span>
											<span class="inline-block rounded-full border border-amber-200/60 px-2.5 py-0.5 font-['JetBrains_Mono'] text-[11px] text-[#8d7e68] dark:border-amber-900/20 dark:text-[#a89a84]">
												{typeLabel}
											</span>
											<span class="inline-block rounded-full border border-amber-200/60 px-2.5 py-0.5 font-['JetBrains_Mono'] text-[11px] text-[#8d7e68] dark:border-amber-900/20 dark:text-[#a89a84]">
												{categoryLabel}
											</span>
										</div>

										{/* Title & description */}
										<h3 class="font-['Playfair_Display'] text-lg font-semibold text-amber-900 dark:text-amber-100">
											{item.title}
										</h3>
										<p class="mt-1 font-['Source_Serif_4'] text-sm leading-relaxed text-[#8d7e68] dark:text-[#a89a84]">
											{item.description}
										</p>

										{/* Date */}
										<p class="mt-3 font-['JetBrains_Mono'] text-[11px] text-amber-400 dark:text-[#6e6150]">
											{item.date}
										</p>
									</div>
								</div>
							</ScrollReveal>
						);
					})}
				</div>
			</div>
		</div>
	</section>

	<Footer />
</Landing>
