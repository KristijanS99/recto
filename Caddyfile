{$CADDY_GLOBAL_OPTIONS}

{$RECTO_DOMAIN:localhost} {
	handle /mcp {
		reverse_proxy mcp:3001
	}

	handle /mcp/* {
		reverse_proxy mcp:3001
	}

	handle /.well-known/oauth-authorization-server {
		reverse_proxy api:3000
	}

	handle /authorize {
		reverse_proxy api:3000
	}

	handle /token {
		reverse_proxy api:3000
	}

	handle /register {
		reverse_proxy api:3000
	}

	handle {
		basic_auth {
			{$RECTO_WEB_USER:admin} {$RECTO_WEB_PASSWORD_HASH}
		}

		handle_path /api/* {
			reverse_proxy api:3000 {
				header_up Authorization "Bearer {$RECTO_API_KEY}"
			}
		}

		handle_path /api {
			reverse_proxy api:3000 {
				header_up Authorization "Bearer {$RECTO_API_KEY}"
			}
		}

		root * /srv/web
		try_files {path} /index.html
		file_server
	}
}
